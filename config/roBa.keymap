&kp F1      &kp F2        &kp F3     &kp F4     &kp F5                              &kp SQT    &kp AMPS  &kp ASTRK  &kp LPAR   &kp RPAR
&kp F6      &kp F7        &kp F8     &kp F9     &kp F10      &none       &kp UNDER  &kp EQUAL  &kp DLLR  &kp PRCNT  &kp CARET  &kp BSLH
&kp F11     &kp F12       &kp F13    &kp F14    &kp F15    &kp F16       &kp LBKT   &kp RBKT   &kp EXCL  &kp AT     &kp HASH   &kp PIPE
&kp LCTRL   &kp LEFT_WIN  &kp LEFT_ALT  &none    &none       &none       &none      &none                                      &kp GRAVE
            >;
        };

//Layer4
        MISC {
            display-name = "MISC";
            bindings = <
&to_kp 5 TAB          &kp LC(LG(LEFT))        &kp LG(TAB)       &kp LG(LC(RIGHT))        &td_alt_f4                                                         &td_alt_f4  &kp LC(W)                 &kp LS(LC(T))          &kp LC(T)          &to_kp 5 TAB
&to_kp 6 TAB          &kp LG(LS(LEFT_ARROW))  &kp LG(UP_ARROW)  &kp LG(LS(RIGHT_ARROW))  &kp F5            &none                &kp C_VOLUME_UP             &kp F5      &kp_exit_AML LC(PAGE_UP)  &kp_exit_AML UP_ARROW  &kp LC(PAGE_DOWN)  &to_kp 6 TAB
&kp LA(LC(LG(DOWN)))  &kp LG(LEFT_ARROW)      &kp LG(DOWN)      &kp LG(RIGHT_ARROW)      &screenshot_copy  &screensot_save      &kp_exit_AML C_VOLUME_DOWN  &kp K_MUTE  &kp LA(LEFT)              &kp DOWN               &kp LA(RIGHT)      &none 
&none                 &none                   &none             &none                    &none             &none                &kp DELETE                  &none                                                                           &none 
            >;

            sensor-bindings = <&inc_dec_kp LC(PAGE_UP) LC(PAGE_DOWN)>;
        };

//Layer5
        ALT_TAB {
            display-name = "ALT TAB";
